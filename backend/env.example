# 环境配置
ENV=development
PORT=8080

# 数据库配置
# 使用 SQLite（开发环境）
DB_TYPE=sqlite
DB_PATH=./gymapp.db

# 使用 PostgreSQL（生产环境）
# DB_TYPE=postgres
# DATABASE_URL=postgres://user:password@localhost:5432/gymapp
# 或者使用单独配置
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=gymapp
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=your_password

# 认证配置（后续添加）
# AUTH_SECRET=your-secret-key
